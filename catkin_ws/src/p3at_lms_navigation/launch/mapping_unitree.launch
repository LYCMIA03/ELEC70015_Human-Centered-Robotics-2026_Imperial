<launch>
  <!--
    Gazebo 仿真 SLAM 建图 — 使用 Unitree 4D Lidar L1 (360° FOV)
    机器人模型: p3at_unitree.urdf.xacro (仅含 Unitree，无 SICK)
    gmapping/move_base 均使用 /unitree/scan，sensor_frame=unitree_lidar

    启动:
      roslaunch p3at_lms_navigation mapping_unitree.launch
      roslaunch p3at_lms_navigation mapping_unitree.launch gui:=false
  -->
  <arg name="gui" default="true"/>
  <arg name="world" default="$(find p3at_lms_gazebo)/worlds/p3at_lms.world"/>
  <arg name="use_gazebo_target" default="true"/>
  <arg name="use_rviz_goal_relay" default="false"/>
  <arg name="use_target_follower" default="$(arg use_gazebo_target)"/>
  <arg name="target_spawn_x" default="4.0"/>
  <arg name="target_spawn_y" default="0.0"/>
  <arg name="target_spawn_z" default="0.0"/>
  <arg name="enable_rplidar_local_obstacle" default="true"/>
  <arg name="rplidar_scan_raw_topic" default="/scan"/>
  <arg name="rplidar_scan_filtered_topic" default="/rplidar/scan_filtered"/>
  <arg name="camera_frame" default="rgbd_camera"/>
  <arg name="standoff_distance" default="0.0"/>
  <arg name="face_target" default="false"/>
  <arg name="target_timeout" default="2.0"/>
  <arg name="enable_auto_explore" default="false"/>
  <arg name="close_approach_threshold" default="1.15"/>
  <arg name="close_approach_timeout" default="18.0"/>
  <arg name="close_approach_speed" default="0.10"/>
  <arg name="close_approach_steer_gain" default="0.50"/>
  <arg name="move_target" default="false"/>
  <arg name="target_speed" default="0.4"/>
  <arg name="target_pause" default="1.0"/>
  <arg name="target_waypoints"
       default="[[2.8,0.0],[2.8,1.8],[0.6,1.8],[0.6,-1.8],[2.8,-1.8],[2.8,0.0]]"/>

  <!-- Gazebo with dual-lidar robot model -->
  <include file="$(find p3at_lms_gazebo)/launch/sim_unitree.launch">
    <arg name="gui" value="$(arg gui)"/>
    <arg name="world" value="$(arg world)"/>
    <arg name="target_x" value="$(arg target_spawn_x)"/>
    <arg name="target_y" value="$(arg target_spawn_y)"/>
    <arg name="target_z" value="$(arg target_spawn_z)"/>
  </include>

  <!-- slam_gmapping — subscribes to Unitree scan -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <rosparam file="$(find p3at_lms_navigation)/param/unitree/gmapping.yaml" command="load"/>
    <remap from="scan" to="/unitree/scan"/>
  </node>

  <!-- move_base — costmaps use Unitree scan -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen" respawn="false">
    <rosparam file="$(find p3at_lms_navigation)/param/unitree/costmap_common.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find p3at_lms_navigation)/param/unitree/costmap_common.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find p3at_lms_navigation)/param/unitree/global_costmap.yaml" command="load"/>
    <rosparam file="$(find p3at_lms_navigation)/param/unitree/local_costmap.yaml" command="load"/>
    <rosparam file="$(find p3at_lms_navigation)/param/unitree/move_base.yaml" command="load"/>
    <rosparam if="$(arg enable_rplidar_local_obstacle)"
              param="local_costmap/obstacle_layer/observation_sources">unitree_scan_sensor rplidar_scan_sensor</rosparam>
  </node>

  <node if="$(arg enable_rplidar_local_obstacle)"
        pkg="target_follower" type="scan_body_filter.py"
        name="rplidar_scan_body_filter" output="screen">
    <param name="body_x_min" value="-0.35"/>
    <param name="body_x_max" value="0.35"/>
    <param name="body_y_min" value="-0.30"/>
    <param name="body_y_max" value="0.30"/>
    <param name="lidar_x" value="-0.232"/>
    <param name="lidar_y" value="0.0"/>
    <remap from="~scan_raw" to="$(arg rplidar_scan_raw_topic)"/>
    <remap from="~scan_out" to="$(arg rplidar_scan_filtered_topic)"/>
  </node>

  <!-- Target following (optional) -->
  <include file="$(find target_follower)/launch/target_follow.launch" if="$(arg use_target_follower)">
    <arg name="use_gazebo_target" value="$(arg use_gazebo_target)"/>
    <arg name="use_rviz_goal_relay" value="$(arg use_rviz_goal_relay)"/>
    <arg name="camera_frame" value="$(arg camera_frame)"/>
    <arg name="standoff_distance" value="$(arg standoff_distance)"/>
    <arg name="face_target" value="$(arg face_target)"/>
    <arg name="target_timeout" value="$(arg target_timeout)"/>
    <arg name="enable_auto_explore" value="$(arg enable_auto_explore)"/>
    <arg name="close_approach_threshold" value="$(arg close_approach_threshold)"/>
    <arg name="close_approach_timeout" value="$(arg close_approach_timeout)"/>
    <arg name="close_approach_speed" value="$(arg close_approach_speed)"/>
    <arg name="close_approach_steer_gain" value="$(arg close_approach_steer_gain)"/>
    <arg name="move_target" value="$(arg move_target)"/>
    <arg name="target_speed" value="$(arg target_speed)"/>
    <arg name="target_pause" value="$(arg target_pause)"/>
    <arg name="target_waypoints" value="$(arg target_waypoints)"/>
  </include>

  <node pkg="rviz" type="rviz" name="rviz"
        args="-d $(find p3at_lms_navigation)/rviz/nav_unitree.rviz" required="false"/>
</launch>
