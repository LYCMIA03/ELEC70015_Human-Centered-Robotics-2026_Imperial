<launch>
  <!--
    真机导航 Launch（Jetson Orin Nano 上运行）
    功能：LMS200 激光雷达 + AMCL 定位（已有地图）+ move_base + target_follower
    前提：树莓派已启动 p3at_base/base.launch（rosaria 底盘驱动，发布 /odom + /cmd_vel）
    
    启动：
      roslaunch p3at_lms_navigation real_robot_nav.launch map_file:=/path/to/your_map.yaml
  -->

  <!-- ========== 参数 ========== -->
  <arg name="lms200_port"        default="/dev/ttyUSB0"/>
  <arg name="lms200_baud"        default="38400"/>
  <arg name="map_file"           default="$(find p3at_lms_navigation)/maps/demo_map.yaml"/>
  <arg name="use_rviz"           default="true"/>
  <arg name="use_target_follower" default="false"/>
  <arg name="use_rviz_goal_relay" default="false"/>
  <arg name="use_udp_target_bridge" default="false"/>
  <arg name="udp_bind_host" default="0.0.0.0"/>
  <arg name="udp_bind_port" default="15001"/>
  <arg name="udp_default_frame" default="camera_link"/>
  <arg name="use_mock_detector" default="false"/>
  <arg name="use_point_target_bridge" default="$(arg use_udp_target_bridge)"/>
  <arg name="point_target_topic" default="/trash_detection/target_point"/>
  <arg name="point_target_frame" default=""/>
  <arg name="mock_target_frame" default="base_link"/>
  <arg name="mock_mode" default="fixed"/>
  <arg name="mock_rate_hz" default="5.0"/>
  <arg name="mock_x" default="2.0"/>
  <arg name="mock_y" default="0.0"/>
  <arg name="mock_z" default="0.0"/>
  <arg name="mock_circle_radius" default="1.5"/>
  <arg name="mock_circle_center_x" default="2.0"/>
  <arg name="mock_circle_center_y" default="0.0"/>
  <arg name="mock_angular_speed" default="0.3"/>
  <arg name="standoff_distance"   default="0.0"/>
  <arg name="face_target"          default="false"/>

  <!-- ========== LMS200 激光雷达驱动 ========== -->
  <node pkg="sicktoolbox_wrapper" type="sicklms" name="sicklms"
        output="screen" respawn="true">
    <param name="port"            value="$(arg lms200_port)"/>
    <param name="baud"            value="$(arg lms200_baud)"/>
    <param name="frame_id"        value="laser"/>
    <param name="resolution"      value="0.5"/>
    <param name="measuring_units" value="cm"/>
  </node>

  <!-- ========== 机器人模型 & TF ========== -->
  <param name="robot_description"
         command="$(find xacro)/xacro $(find p3at_lms_description)/urdf/p3at_lms.urdf.xacro"/>
  <node pkg="robot_state_publisher" type="robot_state_publisher"
        name="robot_state_publisher" output="screen"/>

  <!-- ========== 地图服务 ========== -->
  <node pkg="map_server" type="map_server" name="map_server"
        args="$(arg map_file)" output="screen"/>

  <!-- ========== AMCL 定位 ========== -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <rosparam file="$(find p3at_lms_navigation)/param/amcl.yaml" command="load"/>
    <remap from="scan" to="/scan"/>
  </node>

  <!-- ========== move_base 导航 ========== -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen" respawn="false">
    <rosparam file="$(find p3at_lms_navigation)/param/costmap_common.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find p3at_lms_navigation)/param/costmap_common.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find p3at_lms_navigation)/param/global_costmap.yaml" command="load"/>
    <rosparam file="$(find p3at_lms_navigation)/param/local_costmap.yaml"  command="load"/>
    <rosparam file="$(find p3at_lms_navigation)/param/move_base.yaml"      command="load"/>
  </node>

  <!-- ========== 目标追踪（可选） ========== -->
  <group if="$(arg use_target_follower)">
    <group if="$(arg use_udp_target_bridge)">
      <node pkg="target_follower" type="udp_target_bridge.py"
            name="udp_target_bridge" output="screen">
        <param name="bind_host" value="$(arg udp_bind_host)"/>
        <param name="bind_port" value="$(arg udp_bind_port)"/>
        <param name="out_topic" value="$(arg point_target_topic)"/>
        <param name="default_frame" value="$(arg udp_default_frame)"/>
      </node>
    </group>

    <group if="$(arg use_mock_detector)">
      <node pkg="target_follower" type="mock_target_point_publisher.py"
            name="mock_target_point_publisher" output="screen">
        <param name="topic" value="$(arg point_target_topic)"/>
        <param name="frame_id" value="$(arg mock_target_frame)"/>
        <param name="mode" value="$(arg mock_mode)"/>
        <param name="rate_hz" value="$(arg mock_rate_hz)"/>
        <param name="x" value="$(arg mock_x)"/>
        <param name="y" value="$(arg mock_y)"/>
        <param name="z" value="$(arg mock_z)"/>
        <param name="circle_radius" value="$(arg mock_circle_radius)"/>
        <param name="circle_center_x" value="$(arg mock_circle_center_x)"/>
        <param name="circle_center_y" value="$(arg mock_circle_center_y)"/>
        <param name="angular_speed" value="$(arg mock_angular_speed)"/>
      </node>
    </group>

    <group if="$(arg use_point_target_bridge)">
      <node pkg="target_follower" type="point_to_target_pose.py" name="point_to_target_pose" output="screen">
        <param name="in_point_topic" value="$(arg point_target_topic)"/>
        <param name="out_target_topic" value="/target_pose"/>
        <param name="override_frame" value="$(arg point_target_frame)"/>
      </node>
    </group>

    <node pkg="target_follower" type="target_follower.py" name="target_follower" output="screen">
      <param name="target_topic" value="/target_pose"/>
      <param name="global_frame" value="map"/>
      <param name="robot_frame"  value="base_link"/>
      <param name="send_rate_hz" value="2.0"/>
      <param name="min_update_dist" value="0.25"/>
      <param name="use_target_orientation" value="false"/>
      <param name="target_timeout_s" value="2.0"/>
      <param name="standoff_distance" value="$(arg standoff_distance)"/>
      <param name="face_target" value="$(arg face_target)"/>
    </node>
  </group>

  <!-- RViz 2D Nav Goal 中继 -->
  <group if="$(arg use_rviz_goal_relay)">
    <node pkg="target_follower" type="goal_to_target_relay.py"
          name="goal_to_target_relay" output="screen"/>
  </group>

  <!-- ========== RViz 可视化 ========== -->
  <node if="$(arg use_rviz)"
        pkg="rviz" type="rviz" name="rviz"
        args="-d $(find p3at_lms_navigation)/rviz/nav.rviz"/>
</launch>
