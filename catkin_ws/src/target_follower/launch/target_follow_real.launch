<launch>
  <!--
    真机目标追踪 — Target Following (Real Robot)

    两种模式:
      A) 独立模式 (launch_move_base:=true, 默认):
         自带 Unitree LiDAR + move_base (local-only costmap, 无需全局地图/gmapping).
         只需树莓派 base.launch 已启动.
      B) 叠加模式 (launch_move_base:=false):
         需要已运行的 move_base (如 real_robot_mapping_unitree.launch).

    功能:
      1. (可选) Unitree L1 LiDAR 驱动 + pointcloud_to_laserscan
      2. (可选) move_base — rolling-window costmap in odom frame
      3. udp_target_bridge        接收检测结果 (UDP JSON → /trash_detection/target_point)
      4. point_to_target_pose     PointStamped → PoseStamped (/target_pose)
      5. target_follower          /target_pose → MoveBaseGoal (带 standoff + face_target)
      6. static TF                base_link → camera_link

    启动:
      roslaunch target_follower target_follow_real.launch
      roslaunch target_follower target_follow_real.launch standoff_distance:=0.8 face_target:=true
      roslaunch target_follower target_follow_real.launch launch_move_base:=false   # 叠加到已有 move_base

    结果 topic:
      /target_follower/result  (std_msgs/Bool)   — True=到达目标(触发对话), False=失败/丢失
      /target_follower/status  (std_msgs/String)  — 当前状态: IDLE|TRACKING|REACHED|WAITING_ACTION|POST_ACCEPT_COOLDOWN|RETREATING|LOST|FAILED
      /trash_action            (std_msgs/Bool)    — 对话结果输入: True=接受投递, False=拒绝→触发后退
  -->

  <!-- ========== 参数 ========== -->
  <arg name="launch_move_base"       default="true"
       doc="true=独立模式(自带LiDAR+move_base); false=叠加已有move_base"/>
  <arg name="unitree_port"           default="/dev/ttyUSB0"/>
  <arg name="udp_port"               default="16031"
       doc="UDP 端口, 与检测脚本 ‑‑udp-port 一致"/>
  <arg name="standoff_distance"      default="0.6"
       doc="在距目标多远处停下 (m). 0=直接到达目标位置"/>
  <arg name="face_target"            default="true"
       doc="到达后机器人是否朝向目标"/>
  <arg name="target_timeout"         default="5.0"
       doc="目标消失多久后取消导航 (s)"/>
  <arg name="send_rate_hz"           default="2.0"
       doc="向 move_base 发送新目标的最大频率 (Hz)"/>
  <arg name="min_update_dist"        default="0.2"
       doc="目标移动多远才重发目标 (m)"/>

  <!-- Dialogue integration params -->
  <arg name="trash_action_topic"     default="/trash_action"
       doc="udp_trash_action_bridge 发布的对话结果 topic (Bool: True=接受, False=拒绝)"/>
  <arg name="action_wait_timeout"    default="45.0"
       doc="等待对话结果的超时时间 (s), 超时后重置为 IDLE"/>
  <arg name="post_accept_cooldown"   default="15.0"
       doc="收到 trash_action=True 后的冷却时长 (s), 冷却期间忽略目标追踪"/>
  <arg name="retreat_distance"       default="1.5"
       doc="人类拒绝投垃圾后机器人后退的距离 (m)"/>
  <arg name="retreat_timeout"        default="20.0"
       doc="后退导航的最大等待时间 (s)"/>

  <!-- Resolve global_frame: standalone→odom, overlay→map -->
  <arg name="global_frame" default="odom" if="$(arg launch_move_base)"/>
  <arg name="global_frame" default="map" unless="$(arg launch_move_base)"/>

  <!-- ============================================================ -->
  <!--  独立模式: Unitree LiDAR + robot_description + move_base     -->
  <!-- ============================================================ -->
  <group if="$(arg launch_move_base)">

    <!-- Unitree 4D Lidar L1 驱动 -->
    <param name="/unitree_lidar_ros_node/port"        value="$(arg unitree_port)"/>
    <param name="/unitree_lidar_ros_node/cloud_frame" value="unitree_lidar"/>
    <param name="/unitree_lidar_ros_node/imu_frame"   value="unitree_lidar"/>
    <node pkg="unitree_lidar_ros" type="unitree_lidar_ros_node" name="unitree_lidar"
          output="screen" respawn="true">
      <param name="port"            value="$(arg unitree_port)"/>
      <param name="frame_id"        value="unitree_lidar"/>
      <param name="rotate_yaw_bias" value="0"/>
      <param name="range_start"     value="0.05"/>
      <param name="range_end"       value="30.0"/>
    </node>

    <!-- PointCloud2 → LaserScan (full 360°) -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
          name="pointcloud_to_laserscan" output="screen">
      <remap from="cloud_in" to="/unilidar/cloud"/>
      <remap from="scan"     to="/unitree/scan_raw"/>
      <rosparam>
        target_frame: ""
        min_height: -0.5
        max_height: 0.5
        angle_min: -3.14159265
        angle_max:  3.14159265
        range_min: 0.35
        range_max: 30.0
        use_inf: true
        inf_epsilon: 1.0
      </rosparam>
    </node>

    <!-- Self-detection filter: remove scan points inside robot body -->
    <node pkg="target_follower" type="scan_body_filter.py"
          name="scan_body_filter" output="screen">
      <remap from="~scan_raw" to="/unitree/scan_raw"/>
      <remap from="~scan_out" to="/unitree/scan"/>
    </node>

    <!-- 机器人模型 & TF -->
    <param name="robot_description"
           command="$(find xacro)/xacro $(find p3at_lms_description)/urdf/p3at_unitree.urdf.xacro"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher"
          name="robot_state_publisher" output="screen"/>

    <!-- move_base: local-only costmap (rolling window in odom frame, 无需 /map) -->
    <node pkg="move_base" type="move_base" name="move_base" output="screen" respawn="false">
      <rosparam file="$(find p3at_lms_navigation)/param/unitree/costmap_common.yaml" command="load" ns="global_costmap"/>
      <rosparam file="$(find p3at_lms_navigation)/param/unitree/costmap_common.yaml" command="load" ns="local_costmap"/>
      <rosparam file="$(find p3at_lms_navigation)/param/unitree/global_costmap_local_only.yaml" command="load"/>
      <rosparam file="$(find p3at_lms_navigation)/param/unitree/local_costmap.yaml"  command="load"/>
      <rosparam file="$(find p3at_lms_navigation)/param/unitree/move_base.yaml"      command="load"/>
    </node>

  </group>

  <!-- ============================================================ -->
  <!--  Static TF: base_link → camera_link (ROS→optical)            -->
  <!-- ============================================================ -->
  <!--
    base_link (ROS):   X→前, Y→左, Z→上
    camera_link (光学): X→右, Y→下, Z→前

    真机布局：摄像头通过铝型材固定，水平位置与雷达相同 (x=0.208)，
    高度距轮子最低点 1.0 m (z=1.0)。
    平移: x=0.208  y=0  z=1.0

    static_transform_publisher 的四元数描述 child(camera_link) 在 parent(base_link) 中的朝向。
    lookup_transform("base_link","camera_link") 返回的旋转矩阵 R 将 camera 坐标转换为 base 坐标：

      base_X =  camera_Z   (前)
      base_Y = -camera_X   (左)
      base_Z = -camera_Y   (上)

    对应旋转矩阵 R = [[0, 0, 1], [-1, 0, 0], [0, -1, 0]]
    四元数 (-0.5, 0.5, -0.5, 0.5)   RPY: [-90°, 0°, -90°]
  -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="camera_link_tf"
        args="0.208 0 1.0 -0.5 0.5 -0.5 0.5 base_link camera_link"/>

  <!-- ========== UDP Bridge: detection → ROS ========== -->
  <node pkg="target_follower" type="udp_target_bridge.py" name="udp_target_bridge" output="screen">
    <param name="bind_host"     value="0.0.0.0"/>
    <param name="bind_port"     value="$(arg udp_port)"/>
    <param name="default_frame" value="camera_link"/>
    <param name="out_topic"     value="/trash_detection/target_point"/>
    <param name="stamp_now"     value="true"/>
  </node>

  <!-- ========== PointStamped → PoseStamped 转换 ========== -->
  <node pkg="target_follower" type="point_to_target_pose.py" name="point_to_target_pose" output="screen">
    <param name="in_point_topic"  value="/trash_detection/target_point"/>
    <param name="out_target_topic" value="/target_pose"/>
    <param name="stamp_now"       value="true"/>
  </node>

  <!-- ========== Target Follower: /target_pose → move_base goal ========== -->
  <node pkg="target_follower" type="target_follower.py" name="target_follower" output="screen">
    <param name="target_topic"           value="/target_pose"/>
    <param name="global_frame"           value="$(arg global_frame)"/>
    <param name="robot_frame"            value="base_link"/>
    <param name="send_rate_hz"           value="$(arg send_rate_hz)"/>
    <param name="min_update_dist"        value="$(arg min_update_dist)"/>
    <param name="use_target_orientation" value="false"/>
    <param name="target_timeout_s"       value="$(arg target_timeout)"/>
    <param name="standoff_distance"      value="$(arg standoff_distance)"/>
    <param name="face_target"            value="$(arg face_target)"/>
    <!-- Dialogue integration -->
    <param name="trash_action_topic"     value="$(arg trash_action_topic)"/>
    <param name="action_wait_timeout_s"  value="$(arg action_wait_timeout)"/>
    <param name="post_accept_cooldown_s" value="$(arg post_accept_cooldown)"/>
    <param name="retreat_distance"       value="$(arg retreat_distance)"/>
    <param name="retreat_timeout_s"      value="$(arg retreat_timeout)"/>
  </node>
</launch>
