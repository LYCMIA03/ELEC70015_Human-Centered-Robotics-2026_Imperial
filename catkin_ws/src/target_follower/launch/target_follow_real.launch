<launch>
  <!--
    真机目标追踪 — Target Following (Real Robot)

    两种模式:
      A) 在线SLAM任务模式 (launch_move_base:=true, use_online_slam:=true, 默认):
         自带 LiDAR + gmapping + move_base + frontier-aware target_follower.
      B) 叠加模式 (launch_move_base:=false):
         叠加到外部 move_base（如 map-assisted 导航）.

    功能:
      1. (可选) Unitree L1 / RPLIDAR A2 驱动
      2. (可选) move_base — rolling-window costmap in odom frame
      3. udp_target_bridge        接收检测结果 (UDP JSON → /trash_detection/target_point)
      4. point_to_target_pose     PointStamped → PoseStamped (/target_pose)
      5. target_follower          /target_pose → MoveBaseGoal (带 standoff + face_target)
      6. robot_state_publisher    发布 URDF 中的 base_link → {laser,camera_link} 外参

    当前策略:
      - lidar_mode:=dual    → Unitree 主传感器 + RPLIDAR 近场补充
      - lidar_mode:=unitree → 保留原单雷达逻辑
      - lidar_mode:=rplidar → 纯 RPLIDAR 独立模式
  -->

  <!-- ========== 参数 ========== -->
  <arg name="launch_move_base"       default="true"
       doc="true=独立模式(自带LiDAR+move_base); false=叠加已有move_base"/>
  <arg name="use_online_slam"        default="true"
       doc="当 launch_move_base=true 时, true=在线SLAM(map权威), false=仅本地odom规划(legacy)"/>
  <arg name="lidar_mode"             default="dual"
       doc="独立模式雷达策略: dual|unitree|rplidar"/>
  <arg name="publish_robot_state_in_overlay" default="true"
       doc="overlay模式下是否发布robot_description/TF，建议保持true以使用统一URDF外参"/>
  <arg name="unitree_port"           default="/dev/unitree_lidar"/>
  <arg name="rplidar_port"           default="/dev/rplidar_lidar"/>
  <arg name="rplidar_baud"           default="256000"/>
  <!-- RPLIDAR-only workaround: opt in here so the driver overlay stays easy to revert. -->
  <arg name="rplidar_pre_start_motor" default="true"/>
  <arg name="rplidar_pre_start_motor_pwm" default="600"/>
  <arg name="rplidar_pre_start_motor_warmup_s" default="2.0"/>
  <arg name="scan_startup_timeout"   default="20.0"/>
  <arg name="slam_map_topic" default="/map"/>
  <arg name="slam_map_updates_topic" default="/map_updates"/>
  <arg name="slam_map_metadata_topic" default="/map_metadata"/>
  <arg name="slam_map_frame" default="map"/>
  <arg name="slam_odom_frame" default="odom"/>
  <arg name="slam_base_frame" default="base_link"/>
  <arg name="slam_gmapping_param_file" default="$(find p3at_lms_navigation)/param/rplidar/gmapping.yaml"
       if="$(eval arg('lidar_mode') == 'rplidar')"/>
  <arg name="slam_gmapping_param_file" default="$(find p3at_lms_navigation)/param/unitree/gmapping.yaml"
       unless="$(eval arg('lidar_mode') == 'rplidar')"/>
  <arg name="slam_scan_topic" default="/scan_filtered" if="$(eval arg('lidar_mode') == 'rplidar')"/>
  <arg name="slam_scan_topic" default="/unitree/scan" unless="$(eval arg('lidar_mode') == 'rplidar')"/>
  <arg name="udp_port"               default="16031"
       doc="UDP 端口, 与检测脚本 --udp-port 一致"/>
  <arg name="standoff_distance"      default="0.6"
       doc="在距目标多远处停下 (m). 0=直接到达目标位置"/>
  <arg name="face_target"            default="true"
       doc="到达后机器人是否朝向目标"/>
  <arg name="target_timeout"         default="5.0"
       doc="目标消失多久后取消导航 (s)"/>
  <arg name="send_rate_hz"           default="2.0"
       doc="向 move_base 发送新目标的最大频率 (Hz)"/>
  <arg name="min_update_dist"        default="0.2"
       doc="目标移动多远才重发目标 (m)"/>

  <!-- Dialogue integration params -->
  <arg name="trash_action_topic"     default="/trash_action"
       doc="udp_trash_action_bridge 发布的对话结果 topic (Bool: True=接受, False=拒绝)"/>
  <arg name="action_wait_timeout"    default="45.0"
       doc="等待对话结果的超时时间 (s), 超时后重置为 IDLE"/>
  <arg name="post_accept_cooldown"   default="15.0"
       doc="Cooldown after trash_action=True so the user can finish dropping trash before retreating"/>
  <arg name="retreat_distance"       default="1.5"
       doc="对话后机器人前进撤离的距离 (m)"/>
  <arg name="retreat_timeout"        default="20.0"
       doc="后退导航的最大等待时间 (s)"/>
  <arg name="retreat_turn_angle_deg" default="100.0"
       doc="Retreat turn angle (deg). Use a moderate turn to leave the interaction area without over-rotating into nearby obstacles"/>
  <arg name="retreat_reverse_enabled" default="true"
       doc="是否启用对话后倒车优先撤离"/>
  <arg name="retreat_reverse_distance" default="0.50"
       doc="倒车优先阶段的目标距离 (m)"/>
  <arg name="retreat_reverse_speed" default="0.10"
       doc="倒车速度绝对值 (m/s)"/>
  <arg name="retreat_reverse_safety_margin" default="0.20"
       doc="倒车所需额外安全余量 (m)"/>
  <arg name="retreat_reverse_scan_stale" default="0.8"
       doc="用于倒车安全判断的scan最大允许延迟 (s)"/>
  <arg name="retreat_reverse_rear_sector_deg" default="35.0"
       doc="倒车方向后扇区半角 (deg)"/>

  <!-- Auto-explore params -->
    <arg name="enable_auto_explore"      default="true" doc="无目标时自动探索"/>
  <arg name="explore_goal_distance"    default="2.2" doc="frontier探索短视距子目标长度 (m)"/>
  <arg name="explore_short_horizon"    default="2.2" doc="frontier approach投影的短视距上限 (m)"/>
  <arg name="explore_goal_max_dist"    default="6.0" doc="frontier候选点允许的最大距离 (m)"/>
  <arg name="explore_goal_timeout"     default="30.0" doc="单个探索目标超时 (s)"/>
  <arg name="explore_target_confirm"   default="0.8" doc="How long a target stream must stay stable before exploration is interrupted"/>
  <arg name="explore_target_max_gap"   default="1.0" doc="Maximum allowed gap between target updates while considering the target stable"/>
  <arg name="explore_stuck_timeout"    default="8.0" doc="Replan exploration if odometry progress stays too small for this long (s)"/>
  <arg name="explore_min_progress"     default="0.2" doc="Minimum odometry progress expected before explore is considered stuck (m)"/>
  <arg name="explore_zero_cmd_vel_timeout" default="2.0" doc="Replan exploration early if move_base keeps publishing near-zero cmd_vel for this long (s)"/>
  <arg name="explore_revisit_window"   default="120.0" doc="探索去重时间窗 (s), 该时间内避免回到相同区域"/>
  <arg name="explore_revisit_radius"   default="1.5" doc="探索区域去重半径 (m)"/>
  <arg name="explore_min_frontier_size" default="8"/>
  <arg name="explore_map_clearance_m" default="0.35"/>
  <arg name="explore_require_make_plan" default="true"/>
  <arg name="explore_map_topic" default="/map"/>
  <arg name="explore_costmap_topic" default="/move_base/global_costmap/costmap"/>
  <arg name="explore_scan_topic" default="/scan_filtered" if="$(eval arg('lidar_mode') == 'rplidar')"/>
  <arg name="explore_scan_topic" default="/unitree/scan" unless="$(eval arg('lidar_mode') == 'rplidar')"/>
  <arg name="explore_initial_scan_duration" default="4.0"/>
  <arg name="explore_goal_scan_duration" default="2.2"/>
  <arg name="target_reacquire_duration" default="4.0"/>
  <arg name="target_reacquire_block_s" default="120.0" doc="对话后屏蔽重复目标的时长 (s)"/>
  <arg name="target_reacquire_radius"  default="1.6" doc="对话后屏蔽重复目标的半径 (m)"/>

  <!-- Recommended:
       - overlay: map
       - standalone + online_slam: map
       - standalone + legacy local-only: pass global_frame:=odom explicitly -->
  <arg name="global_frame" default="map"/>

  <!-- ============================================================ -->
  <!--  独立模式: selected LiDAR + robot_description + move_base    -->
  <!-- ============================================================ -->
  <group if="$(arg launch_move_base)">

    <group if="$(arg use_online_slam)">
      <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping_online" output="screen">
        <rosparam file="$(arg slam_gmapping_param_file)" command="load"/>
        <param name="map_frame" value="$(arg slam_map_frame)"/>
        <param name="odom_frame" value="$(arg slam_odom_frame)"/>
        <param name="base_frame" value="$(arg slam_base_frame)"/>
        <remap from="scan" to="$(arg slam_scan_topic)"/>
        <remap from="map" to="$(arg slam_map_topic)"/>
        <remap from="map_updates" to="$(arg slam_map_updates_topic)"/>
        <remap from="map_metadata" to="$(arg slam_map_metadata_topic)"/>
      </node>
    </group>

    <group unless="$(eval arg('lidar_mode') == 'rplidar')">
      <!-- Unitree 4D Lidar L1 驱动 -->
      <param name="/unitree_lidar_ros_node/port"        value="$(arg unitree_port)"/>
      <param name="/unitree_lidar_ros_node/cloud_frame" value="unitree_lidar"/>
      <param name="/unitree_lidar_ros_node/imu_frame"   value="unitree_lidar"/>
      <node pkg="unitree_lidar_ros" type="unitree_lidar_ros_node" name="unitree_lidar"
            output="screen" respawn="true">
        <param name="port"            value="$(arg unitree_port)"/>
        <param name="frame_id"        value="unitree_lidar"/>
        <param name="rotate_yaw_bias" value="0"/>
        <param name="range_start"     value="0.05"/>
        <param name="range_end"       value="30.0"/>
      </node>

      <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
            name="pointcloud_to_laserscan" output="screen">
        <remap from="cloud_in" to="/unilidar/cloud"/>
        <remap from="scan"     to="/unitree/scan_raw"/>
        <rosparam>
          target_frame: ""
          min_height: -0.5
          max_height: 0.5
          angle_min: -3.14159265
          angle_max:  3.14159265
          range_min: 0.35
          range_max: 30.0
          use_inf: true
          inf_epsilon: 1.0
        </rosparam>
      </node>

      <node pkg="target_follower" type="scan_body_filter.py"
            name="scan_body_filter" output="screen">
        <remap from="~scan_raw" to="/unitree/scan_raw"/>
        <remap from="~scan_out" to="/unitree/scan"/>
      </node>

      <param name="robot_description"
             command="$(find xacro)/xacro $(find p3at_lms_description)/urdf/p3at_unitree.urdf.xacro"/>
      <node pkg="robot_state_publisher" type="robot_state_publisher"
            name="robot_state_publisher" output="screen"/>

      <group if="$(eval arg('lidar_mode') == 'dual')">
        <node pkg="target_follower" type="rplidar_health_monitor.py" name="rplidar_health_monitor"
              output="screen" required="true">
          <param name="device" value="$(arg rplidar_port)"/>
          <param name="scan_topic" value="/scan"/>
          <param name="startup_timeout" value="$(arg scan_startup_timeout)"/>
          <param name="stale_timeout" value="3.0"/>
        </node>

        <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
          <param name="serial_port"      type="string" value="$(arg rplidar_port)"/>
          <param name="serial_baudrate"  type="int"    value="$(arg rplidar_baud)"/>
          <param name="pre_start_motor" type="bool" value="$(arg rplidar_pre_start_motor)"/>
          <param name="pre_start_motor_pwm" type="int" value="$(arg rplidar_pre_start_motor_pwm)"/>
          <param name="pre_start_motor_warmup_s" type="double" value="$(arg rplidar_pre_start_motor_warmup_s)"/>
          <param name="frame_id"         type="string" value="laser"/>
          <param name="inverted"         type="bool"   value="false"/>
          <param name="angle_compensate" type="bool"   value="true"/>
        </node>

        <node pkg="target_follower" type="scan_body_filter.py"
              name="rplidar_scan_body_filter" output="screen">
          <param name="lidar_x" value="-0.272"/>
          <param name="lidar_y" value="0.0"/>
          <param name="body_x_min" value="-0.27"/>
          <param name="body_x_max" value="0.27"/>
          <param name="body_y_min" value="-0.22"/>
          <param name="body_y_max" value="0.22"/>
          <remap from="~scan_raw" to="/scan"/>
          <remap from="~scan_out" to="/rplidar/scan_filtered"/>
        </node>
      </group>

      <node pkg="move_base" type="move_base" name="move_base" output="screen" respawn="false">
        <rosparam file="$(find p3at_lms_navigation)/param/unitree/costmap_common.yaml" command="load" ns="global_costmap"/>
        <rosparam file="$(find p3at_lms_navigation)/param/unitree/costmap_common.yaml" command="load" ns="local_costmap"/>
        <rosparam file="$(find p3at_lms_navigation)/param/unitree/global_costmap_local_only.yaml" command="load"
                  unless="$(arg use_online_slam)"/>
        <rosparam file="$(find p3at_lms_navigation)/param/unitree/global_costmap_slam.yaml" command="load"
                  if="$(arg use_online_slam)"/>
        <rosparam file="$(find p3at_lms_navigation)/param/unitree/local_costmap.yaml"  command="load"/>
        <rosparam file="$(find p3at_lms_navigation)/param/unitree/move_base.yaml"      command="load"/>
        <param if="$(arg use_online_slam)" name="global_costmap/static_layer/map_topic" value="$(arg slam_map_topic)"/>
        <!-- Dual-lidar policy:
             - local_costmap: Unitree + RPLIDAR (near-field supplement)
             - global_costmap: Unitree only -->
        <rosparam if="$(eval arg('lidar_mode') == 'dual')" param="local_costmap/obstacle_layer/observation_sources">unitree_scan_sensor rplidar_scan_sensor</rosparam>
      </node>
    </group>

    <group if="$(eval arg('lidar_mode') == 'rplidar')">
      <node pkg="target_follower" type="rplidar_health_monitor.py" name="rplidar_health_monitor"
            output="screen" required="true">
        <param name="device" value="$(arg rplidar_port)"/>
        <param name="scan_topic" value="/scan"/>
        <param name="startup_timeout" value="$(arg scan_startup_timeout)"/>
        <param name="stale_timeout" value="3.0"/>
      </node>

      <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
        <param name="serial_port"      type="string" value="$(arg rplidar_port)"/>
        <param name="serial_baudrate"  type="int"    value="$(arg rplidar_baud)"/>
        <param name="pre_start_motor" type="bool" value="$(arg rplidar_pre_start_motor)"/>
        <param name="pre_start_motor_pwm" type="int" value="$(arg rplidar_pre_start_motor_pwm)"/>
        <param name="pre_start_motor_warmup_s" type="double" value="$(arg rplidar_pre_start_motor_warmup_s)"/>
        <param name="frame_id"         type="string" value="laser"/>
        <param name="inverted"         type="bool"   value="false"/>
        <param name="angle_compensate" type="bool"   value="true"/>
      </node>

      <node pkg="target_follower" type="scan_body_filter.py"
            name="scan_body_filter" output="screen">
        <param name="lidar_x" value="-0.272"/>
        <param name="lidar_y" value="0.0"/>
        <param name="body_x_min" value="-0.27"/>
        <param name="body_x_max" value="0.27"/>
        <param name="body_y_min" value="-0.22"/>
        <param name="body_y_max" value="0.22"/>
        <remap from="~scan_raw" to="/scan"/>
        <remap from="~scan_out" to="/scan_filtered"/>
      </node>

      <param name="robot_description"
             command="$(find xacro)/xacro $(find p3at_lms_description)/urdf/p3at_unitree.urdf.xacro"/>
      <node pkg="robot_state_publisher" type="robot_state_publisher"
            name="robot_state_publisher" output="screen"/>

      <node pkg="move_base" type="move_base" name="move_base" output="screen" respawn="false">
        <rosparam file="$(find p3at_lms_navigation)/param/rplidar/costmap_common.yaml" command="load" ns="global_costmap"/>
        <rosparam file="$(find p3at_lms_navigation)/param/rplidar/costmap_common.yaml" command="load" ns="local_costmap"/>
        <rosparam file="$(find p3at_lms_navigation)/param/rplidar/global_costmap_local_only.yaml" command="load"
                  unless="$(arg use_online_slam)"/>
        <rosparam file="$(find p3at_lms_navigation)/param/rplidar/global_costmap_slam.yaml" command="load"
                  if="$(arg use_online_slam)"/>
        <rosparam file="$(find p3at_lms_navigation)/param/rplidar/local_costmap.yaml"  command="load"/>
        <rosparam file="$(find p3at_lms_navigation)/param/rplidar/move_base.yaml"      command="load"/>
        <param if="$(arg use_online_slam)" name="global_costmap/static_layer/map_topic" value="$(arg slam_map_topic)"/>
      </node>
    </group>

  </group>

  <group if="$(eval (arg('launch_move_base') == 'false') and (arg('publish_robot_state_in_overlay') == 'true'))">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find p3at_lms_description)/urdf/p3at_unitree.urdf.xacro"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher"
          name="robot_state_publisher" output="screen"/>
  </group>

  <!-- ========== UDP Bridge: detection → ROS ========== -->
  <node pkg="target_follower" type="udp_target_bridge.py" name="udp_target_bridge" output="screen">
    <param name="bind_host"     value="0.0.0.0"/>
    <param name="bind_port"     value="$(arg udp_port)"/>
    <param name="default_frame" value="camera_link"/>
    <param name="out_topic"     value="/trash_detection/target_point"/>
    <param name="stamp_now"     value="true"/>
  </node>

  <!-- ========== PointStamped → PoseStamped 转换 ========== -->
  <node pkg="target_follower" type="point_to_target_pose.py" name="point_to_target_pose" output="screen">
    <param name="in_point_topic"  value="/trash_detection/target_point"/>
    <param name="out_target_topic" value="/target_pose"/>
    <param name="stamp_now"       value="true"/>
  </node>

  <!-- ========== Target Follower: /target_pose → move_base goal ========== -->
  <node pkg="target_follower" type="target_follower.py" name="target_follower" output="screen">
    <param name="target_topic"           value="/target_pose"/>
    <param name="global_frame"           value="$(arg global_frame)"/>
    <param name="robot_frame"            value="base_link"/>
    <param name="camera_frame"           value="camera_link"/>
    <param name="send_rate_hz"           value="$(arg send_rate_hz)"/>
    <param name="min_update_dist"        value="$(arg min_update_dist)"/>
    <param name="use_target_orientation" value="false"/>
    <param name="target_timeout_s"       value="$(arg target_timeout)"/>
    <param name="standoff_distance"      value="$(arg standoff_distance)"/>
    <param name="face_target"            value="$(arg face_target)"/>
    <param name="trash_action_topic"     value="$(arg trash_action_topic)"/>
    <param name="action_wait_timeout_s"  value="$(arg action_wait_timeout)"/>
    <param name="post_accept_cooldown_s" value="$(arg post_accept_cooldown)"/>
    <param name="retreat_distance"       value="$(arg retreat_distance)"/>
    <param name="retreat_timeout_s"      value="$(arg retreat_timeout)"/>
    <param name="retreat_turn_angle_deg" value="$(arg retreat_turn_angle_deg)"/>
    <param name="retreat_reverse_enabled" value="$(arg retreat_reverse_enabled)"/>
    <param name="retreat_reverse_distance" value="$(arg retreat_reverse_distance)"/>
    <param name="retreat_reverse_speed" value="$(arg retreat_reverse_speed)"/>
    <param name="retreat_reverse_safety_margin" value="$(arg retreat_reverse_safety_margin)"/>
    <param name="retreat_reverse_scan_stale_s" value="$(arg retreat_reverse_scan_stale)"/>
    <param name="retreat_reverse_rear_sector_deg" value="$(arg retreat_reverse_rear_sector_deg)"/>
    <param name="enable_auto_explore"    value="$(arg enable_auto_explore)"/>
    <param name="explore_goal_distance"  value="$(arg explore_goal_distance)"/>
    <param name="explore_short_horizon_m" value="$(arg explore_short_horizon)"/>
    <param name="explore_goal_max_dist" value="$(arg explore_goal_max_dist)"/>
    <param name="explore_goal_timeout_s" value="$(arg explore_goal_timeout)"/>
    <param name="explore_target_confirm_s" value="$(arg explore_target_confirm)"/>
    <param name="explore_target_max_gap_s" value="$(arg explore_target_max_gap)"/>
    <param name="explore_stuck_timeout_s" value="$(arg explore_stuck_timeout)"/>
    <param name="explore_min_progress_dist" value="$(arg explore_min_progress)"/>
    <param name="explore_zero_cmd_vel_timeout_s" value="$(arg explore_zero_cmd_vel_timeout)"/>
    <param name="explore_revisit_window_s" value="$(arg explore_revisit_window)"/>
    <param name="explore_revisit_radius" value="$(arg explore_revisit_radius)"/>
    <param name="explore_min_frontier_size" value="$(arg explore_min_frontier_size)"/>
    <param name="explore_map_clearance_m" value="$(arg explore_map_clearance_m)"/>
    <param name="explore_require_make_plan" value="$(arg explore_require_make_plan)"/>
    <param name="explore_map_topic" value="$(arg explore_map_topic)"/>
    <param name="explore_costmap_topic" value="$(arg explore_costmap_topic)"/>
    <param name="explore_scan_topic" value="$(arg explore_scan_topic)"/>
    <param name="explore_initial_scan_duration_s" value="$(arg explore_initial_scan_duration)"/>
    <param name="explore_goal_scan_duration_s" value="$(arg explore_goal_scan_duration)"/>
    <param name="target_reacquire_duration_s" value="$(arg target_reacquire_duration)"/>
    <param name="target_reacquire_block_s" value="$(arg target_reacquire_block_s)"/>
    <param name="target_reacquire_radius" value="$(arg target_reacquire_radius)"/>
  </node>
</launch>
