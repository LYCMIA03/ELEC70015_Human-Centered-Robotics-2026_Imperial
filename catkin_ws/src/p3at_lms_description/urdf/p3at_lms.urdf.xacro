<?xml version="1.0"?>
<!--
  P3-AT integrated full-assembly robot model.
  Includes:
    - Base chassis/wheels + drive plugin
    - RPLIDAR A2M12 (rear-underbody, inverted)
    - Unitree L1 lidar (front-top)
    - RGBD camera + aluminium strut mount structure
  Uses official Pioneer 3-AT mesh files for accurate visual geometry.
-->
<robot name="p3at_lms" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="PI" value="3.1415926535897931"/>

  <!-- Mesh package path prefix -->
  <xacro:property name="mesh_prefix" value="package://p3at_lms_description/meshes/p3at_meshes"/>

  <!-- ======================== base_footprint ======================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Chassis (base_link) ======================== -->
  <link name="base_link">
    <inertial>
      <mass value="21.5"/>
      <origin xyz="-0.1 0 0.177"/>
      <inertia ixx="0.3338" ixy="0.0" ixz="0.0"
               iyy="0.4783" iyz="0.0"
               izz="0.3338"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.177" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}/chassis.stl"/>
      </geometry>
      <material name="ChassisRed">
        <color rgba="0.851 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.177" rpy="0 0 0"/>
      <geometry>
        <!-- Slightly shorter than mesh to keep laser rays clear above -->
        <box size="0.50 0.40 0.16"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <!-- ======================== Top plate ======================== -->
  <link name="top_plate">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="-0.025 0 -0.223"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}/top.stl"/>
      </geometry>
      <material name="TopBlack">
        <color rgba="0.038 0.038 0.038 1.0"/>
      </material>
    </visual>
  </link>
  <gazebo reference="top_plate">
    <material>Gazebo/Black</material>
  </gazebo>

  <joint name="base_top_joint" type="fixed">
    <origin xyz="0.003 0 0.274" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="top_plate"/>
  </joint>

  <!-- ======================== Front sonar ======================== -->
  <link name="front_sonar">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}/front_sonar.stl"/>
      </geometry>
      <material name="SonarYellow">
        <color rgba="0.715 0.583 0.210 1.0"/>
      </material>
    </visual>
  </link>
  <gazebo reference="front_sonar">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <joint name="base_front_joint" type="fixed">
    <origin xyz="0.193 0 0.25" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_sonar"/>
  </joint>

  <!-- ======================== Back sonar ======================== -->
  <link name="back_sonar">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}/back_sonar.stl"/>
      </geometry>
      <material name="SonarYellow">
        <color rgba="0.715 0.583 0.210 1.0"/>
      </material>
    </visual>
  </link>
  <gazebo reference="back_sonar">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <joint name="base_back_joint" type="fixed">
    <origin xyz="-0.187 0 0.247" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="back_sonar"/>
  </joint>

  <!-- ======================== Drive side macro ======================== -->
  <xacro:macro name="p3at_drive_side" params="side reflect">

    <!-- Front axle -->
    <link name="p3at_front_${side}_axle">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_prefix}/axle.stl"/>
        </geometry>
        <material name="AxleGrey">
          <color rgba="0.5 0.5 0.5 1"/>
        </material>
      </visual>
    </link>
    <gazebo reference="p3at_front_${side}_axle">
      <material>Gazebo/Grey</material>
    </gazebo>

    <joint name="base_front_${side}_axle_joint" type="fixed">
      <origin xyz="0.135 ${reflect*0.156} 0.111" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="p3at_front_${side}_axle"/>
    </joint>

    <!-- Front hub -->
    <link name="p3at_front_${side}_hub">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_prefix}/${side}_hubcap.stl"/>
        </geometry>
        <material name="HubcapYellow">
          <color rgba="1.0 0.811 0.151 1.0"/>
        </material>
      </visual>
    </link>
    <gazebo reference="p3at_front_${side}_hub">
      <material>Gazebo/Yellow</material>
    </gazebo>

    <joint name="base_front_${side}_hub_joint" type="fixed">
      <origin xyz="0 ${reflect*0.041} 0" rpy="0 0 0"/>
      <parent link="p3at_front_${side}_axle"/>
      <child link="p3at_front_${side}_hub"/>
    </joint>

    <!-- Front wheel -->
    <link name="p3at_front_${side}_wheel">
      <inertial>
        <mass value="1.2"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.012411765597" ixy="0" ixz="0"
                 iyy="0.015218160428" iyz="0"
                 izz="0.011763977943"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_prefix}/wheel.stl"/>
        </geometry>
        <material name="WheelBlack">
          <color rgba="0.117 0.117 0.117 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${-PI/2} 0 0"/>
        <geometry>
          <cylinder radius="0.111" length="0.075"/>
        </geometry>
      </collision>
    </link>
    <gazebo reference="p3at_front_${side}_wheel">
      <material>Gazebo/Black</material>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <maxVel>1.0</maxVel>
      <minDepth>0.00</minDepth>
    </gazebo>

    <joint name="p3at_front_${side}_wheel_joint" type="continuous">
      <axis xyz="0 1 0"/>
      <limit effort="100" velocity="100"/>
      <joint_properties damping="0.7"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="p3at_front_${side}_hub"/>
      <child link="p3at_front_${side}_wheel"/>
    </joint>

    <!-- Back axle -->
    <link name="p3at_back_${side}_axle">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_prefix}/axle.stl"/>
        </geometry>
        <material name="AxleGrey">
          <color rgba="0.5 0.5 0.5 1"/>
        </material>
      </visual>
    </link>
    <gazebo reference="p3at_back_${side}_axle">
      <material>Gazebo/Grey</material>
    </gazebo>

    <joint name="p3at_back_${side}_axle_joint" type="fixed">
      <origin xyz="-0.134 ${reflect*0.156} 0.111" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="p3at_back_${side}_axle"/>
    </joint>

    <!-- Back hub -->
    <link name="p3at_back_${side}_hub">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_prefix}/${side}_hubcap.stl"/>
        </geometry>
        <material name="HubcapYellow">
          <color rgba="1.0 0.811 0.151 1.0"/>
        </material>
      </visual>
    </link>
    <gazebo reference="p3at_back_${side}_hub">
      <material>Gazebo/Yellow</material>
    </gazebo>

    <joint name="p3at_back_${side}_hub_joint" type="fixed">
      <origin xyz="0 ${reflect*0.041} 0" rpy="0 0 0"/>
      <parent link="p3at_back_${side}_axle"/>
      <child link="p3at_back_${side}_hub"/>
    </joint>

    <!-- Back wheel -->
    <link name="p3at_back_${side}_wheel">
      <inertial>
        <mass value="1.2"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.012411765597" ixy="0" ixz="0"
                 iyy="0.015218160428" iyz="0"
                 izz="0.011763977943"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_prefix}/wheel.stl"/>
        </geometry>
        <material name="WheelBlack">
          <color rgba="0.117 0.117 0.117 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${-PI/2} 0 0"/>
        <geometry>
          <cylinder radius="0.111" length="0.075"/>
        </geometry>
      </collision>
    </link>
    <gazebo reference="p3at_back_${side}_wheel">
      <material>Gazebo/Black</material>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <maxVel>1.0</maxVel>
      <minDepth>0.00</minDepth>
    </gazebo>

    <joint name="p3at_back_${side}_wheel_joint" type="continuous">
      <axis xyz="0 1 0"/>
      <limit effort="100" velocity="100"/>
      <joint_properties damping="0.7"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="p3at_back_${side}_hub"/>
      <child link="p3at_back_${side}_wheel"/>
    </joint>

  </xacro:macro>

  <!-- Instantiate left and right drive sides -->
  <xacro:p3at_drive_side side="left"  reflect="1"/>
  <xacro:p3at_drive_side side="right" reflect="-1"/>

  <!-- ======================== RPLIDAR A2M12 (rear-underbody, inverted) ======================== -->
  <!--
    User mounting requirement (real robot):
      - Mounted under the rear of the chassis ("车屁股下面")
      - Laterally centered (y=0)
      - 1 cm inward from rear outer edge
      - Sensor installed upside-down

    Coordinate convention used here:
      - base_link: +x forward, +y left, +z up
      - P3AT chassis projection rear edge from collision box: x=-0.25 m
      - A2 outer radius approximated as 0.038 m
      - required outer rear edge target: -0.25 + 0.01 = -0.24 m
      - baseline center x from geometry: -0.24 + 0.038 = -0.202 m
      - calibrated runtime offset: x = -0.232 m (shifted further rear by 3 cm)
      - chassis lower surface approximated from base collision box bottom: z=0.097 m
      - A2M12 body height approximated as 0.05 m (visual/collision)

    To satisfy "lidar lower face bonded to chassis lower face" with inverted mount,
    place laser joint at z=0.072 m and rotate 180 deg around X.
  -->
  <link name="laser">
    <inertial>
      <mass value="0.19"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0"
               iyy="0.0003" iyz="0.0"
               izz="0.0003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Approximate A2 body (diameter ~76mm, height ~50mm) -->
        <cylinder radius="0.038" length="0.05"/>
      </geometry>
      <material name="RplidarGrey">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.05"/>
      </geometry>
    </collision>
    <!-- Collision kept for RViz/URDF inspection; Gazebo ray tracing still uses sensor plugin -->
  </link>
  <gazebo reference="laser"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <!-- Rear-underbody, centered, upside-down; outer rim is 1cm inside rear edge -->
    <origin xyz="-0.232 0.0 0.072" rpy="3.1415926535897931 0 0"/>
  </joint>

  <!-- ======================== Unitree 4D Lidar L1 (front-top) ======================== -->
  <!--
    Keep Unitree frame definition in the same full robot URDF for visualization/
    calibration checks. Runtime can still choose which LiDAR topic to consume.
  -->
  <xacro:include filename="$(find p3at_lms_description)/urdf/unitree_lidar_l1.urdf.xacro"/>
  <xacro:unitree_lidar_l1 parent="base_link" prefix="unitree"
                           xyz="0.208 0.0 0.299" rpy="0 0 0"
                           sim_scan_topic="unitree/scan"
                           sim_cloud_topic="unitree/cloud"
                           sim_imu_topic="unitree/imu"
                           enable_3d="true"/>

  <!-- ======================== Aluminium Struts + RGBD Camera ======================== -->
  <!--
    Camera mount follows existing deployment convention:
      - camera center at x=0.208, y=0, z=0.85
      - camera optical orientation remains managed by launch-time static TF
    Two aluminum struts are modeled as vertical cylindrical links.
    Strut lower end touches top plate upper surface at z=0.274.
  -->
  <link name="left_aluminum_strut">
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.70"/>
      </geometry>
      <material name="AluminiumSilver">
        <color rgba="0.72 0.74 0.76 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="left_aluminum_strut_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_aluminum_strut"/>
    <origin xyz="0.18 0.08 0.624" rpy="0 0 0"/>
  </joint>

  <link name="right_aluminum_strut">
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.70"/>
      </geometry>
      <material name="AluminiumSilver"/>
    </visual>
  </link>
  <joint name="right_aluminum_strut_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_aluminum_strut"/>
    <origin xyz="0.18 -0.08 0.624" rpy="0 0 0"/>
  </joint>

  <link name="rgbd_camera_mount_bar">
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.18 0.02"/>
      </geometry>
      <material name="AluminiumSilver"/>
    </visual>
  </link>
  <joint name="rgbd_camera_mount_bar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rgbd_camera_mount_bar"/>
    <origin xyz="0.208 0.0 0.85" rpy="0 0 0"/>
  </joint>

  <link name="rgbd_camera">
    <inertial>
      <mass value="0.09"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
      <material name="CameraBlack">
        <color rgba="0.08 0.08 0.08 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="rgbd_camera_joint" type="fixed">
    <parent link="rgbd_camera_mount_bar"/>
    <child link="rgbd_camera"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Gazebo Skid-Steer Drive Plugin ======================== -->
  <gazebo>
    <plugin name="skid_steer_drive" filename="libgazebo_ros_skid_steer_drive.so">
      <robotNamespace>/</robotNamespace>

      <leftFrontJoint>p3at_front_left_wheel_joint</leftFrontJoint>
      <rightFrontJoint>p3at_front_right_wheel_joint</rightFrontJoint>
      <leftRearJoint>p3at_back_left_wheel_joint</leftRearJoint>
      <rightRearJoint>p3at_back_right_wheel_joint</rightRearJoint>

      <wheelSeparation>0.4</wheelSeparation>
      <wheelDiameter>0.222</wheelDiameter>

      <torque>200</torque>
      <updateRate>50</updateRate>

      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>

      <publishWheelTF>true</publishWheelTF>
      <publishTf>true</publishTf>
      <broadcastTF>true</broadcastTF>
      <publishWheelJointState>true</publishWheelJointState>
    </plugin>
  </gazebo>

  <!-- ======================== Gazebo RPLIDAR-like 2D Sensor ======================== -->
  <gazebo reference="laser">
    <sensor type="ray" name="rplidar_a2m12">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.1415926535897931</min_angle>
            <max_angle> 3.1415926535897931</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.2</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>

      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
