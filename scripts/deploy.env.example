# Copy this file to scripts/deploy.env and fill in real IPs.
# The scripts in ./scripts will load deploy.env automatically when present.

# Jetson ORIN Nano (recommended ROS master in real robot mode)
JETSON_IP=__SET_JETSON_LAN_IP__

# Raspberry Pi controlling the P3-AT base
RASPI_IP=__SET_RASPI_LAN_IP__

# Laptop / WSL host (use your LAN-visible IP, not 127.0.0.1)
LAPTOP_IP=__SET_LAPTOP_LAN_IP__

# Optional: override catkin workspace if not repo_root/catkin_ws
# CATKIN_WS=/absolute/path/to/catkin_ws
