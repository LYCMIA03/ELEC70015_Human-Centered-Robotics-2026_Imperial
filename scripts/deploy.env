# Copy this file to scripts/deploy.env and fill in real IPs.
# The scripts in ./scripts will load deploy.env automatically when present.

# Jetson ORIN Nano (recommended ROS master in real robot mode)
JETSON_IP=192.168.50.1

# Raspberry Pi controlling the P3-AT base
RASPI_IP=192.168.50.2

# Laptop / WSL host (use your LAN-visible IP, not 127.0.0.1)
LAPTOP_IP=__SET_LAPTOP_LAN_IP__

# Optional: override catkin workspace if not repo_root/catkin_ws
# CATKIN_WS=/absolute/path/to/catkin_ws

# UDP port used by trash_detection -> udp_target_bridge (separate from ROS 11311)
TRASH_UDP_PORT=16031

# UDP port used by ROS(/target_follower/result) -> host dialogue runner trigger
DIALOGUE_TRIGGER_UDP_PORT=16041

# UDP port used by host dialogue runner -> ROS(/trash_action)
DIALOGUE_ACTION_UDP_PORT=16032

# Dialogue retrigger policy while /target_follower/status=WAITING_ACTION:
# false = single trigger only (recommended, avoids repeated prompt overlap)
# true  = resend trigger every DIALOGUE_RETRIGGER_INTERVAL_S until /trash_action arrives
DIALOGUE_RETRIGGER_ENABLE=false
DIALOGUE_RETRIGGER_INTERVAL_S=30.0
